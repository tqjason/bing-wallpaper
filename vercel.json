{
	"version": 2,
	"builds": [
		{
			"src": "./index.ts",
			"use": "@vercel/node"
		}
	],
	"rewrites": [
		{
			"source": "/(.*)",
			"destination": "/index.ts"
		}
	],
	"headers": [
		{
			"source": "/(.*)",
			"headers": [
				{
					"key": "Cache-Control",
					"value": "no-store, max-age=0, must-revalidate"
				},
				{ "key": "Access-Control-Allow-Credentials", "value": "true" },
				{ "key": "Access-Control-Allow-Origin", "value": "*" },
				{ "key": "Access-Control-Allow-Methods", "value": "GET" }
			]
		}
	]
}
